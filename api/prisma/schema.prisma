// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum Language {
  ENGLISH
  YORUBA
  IGBO
  HAUSA
  PIDGIN
  FRENCH
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum BiomarkerStatus {
  NORMAL
  BORDERLINE
  CONCERNING
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  MISSED
  CANCELLED
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  FAILED
  ABANDONED
}

enum MessageSender {
  USER
  AI
}

enum EscalationStatus {
  DETECTED
  NOTIFIED
  RESOLVED
  FALSE_POSITIVE
}



model User {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  fullName          String
  email             String?   @unique
  phoneNumber       String    @unique
  whatsappId        String?   @unique
  dateOfBirth       DateTime
  gender            Gender
  preferredLanguage Language  @default(ENGLISH)
  profileImageUrl   String?
  passwordHash      String?

  // Location
  state             String?
  lga               String?
  latitude          Float?
  longitude         Float?

  isActive          Boolean   @default(true)
  isVerified        Boolean   @default(false)
  lastActiveAt      DateTime?

  // Relations
  healthProfile     HealthProfile?
  labResults        LabResult[]
  vitals            Vital[]
  riskAssessments   RiskAssessment[]
  chatSessions      ChatSession[]
  appointments      Appointment[]
  notifications     Notification[]
  escalations       Escalation[]
  gaitLogs          GaitLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// HEALTH PROFILE
// ─────────────────────────────────────────────

model HealthProfile {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  heightCm              Float?
  weightKg              Float?
  bmi                   Float?

  existingConditions    String[]
  familyHistory         String[]
  currentMedications    String[]
  allergies             String[]
  bloodGroup            String?

  smokingStatus         String?
  alcoholUse            String?
  physicalActivityLevel String?
  dietType              String?
  averageSleepHours     Float?
  stressLevel           Int?

  occupation            String?
  incomeLevel           String?

  // Heart rate baseline
  hrBaseline            Float?
  hrStdDev              Float?
  hrReadingCount        Int      @default(0)
  
  // HRV baseline  
  hrvBaseline           Float?
  hrvStdDev             Float?
  
  // Gait baselines
  gaitRegularityBase    Float?
  gaitRegularityStdDev  Float?
  fatigueIndexBase      Float?
  stepsPerWindowBase    Float?
  
  // Respiratory
  respiratoryBase       Float?
  respiratoryStdDev     Float?
  
  // Activity profile
  dominantActivity      String?
  avgDailySteps         Float?
  avgDailyCalories      Float?
  
  // Risk flags derived from trends
  chronicFatigueRisk    Boolean  @default(false)
  elevatedHRRisk        Boolean  @default(false)
  lowHRVRisk            Boolean  @default(false)
  sedentaryRisk         Boolean  @default(false)
  
  // Trend directions — "improving" | "stable" | "declining"
  gaitTrend             String?
  hrTrend               String?
  hrvTrend              String?
  
  // Meta
  lastRecalibrated      DateTime?
  totalScans            Int      @default(0)
  profileConfidence     Float    @default(0) // 0-1, grows with more data

  labMetadata           Json?    @default("{}")

  @@map("health_profiles")
}

// ─────────────────────────────────────────────
// LAB RESULTS
// ─────────────────────────────────────────────

model LabResult {
  id                   String          @id @default(cuid())
  createdAt            DateTime        @default(now())

  userId               String
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  rawText              String?
  documentUrl          String?
  testName             String
  testedAt             DateTime?
  labName              String?

  plainLanguageSummary String?
  overallStatus        BiomarkerStatus @default(NORMAL)
  aiRecommendations    String[]
  interpretedAt        DateTime?

  biomarkers           Biomarker[]

  @@map("lab_results")
}

model Biomarker {
  id           String          @id @default(cuid())

  labResultId  String
  labResult    LabResult       @relation(fields: [labResultId], references: [id], onDelete: Cascade)

  name         String
  value        Float
  unit         String
  referenceMin Float?
  referenceMax Float?
  status       BiomarkerStatus @default(NORMAL)
  flagNote     String?

  @@map("biomarkers")
}

// ─────────────────────────────────────────────
// VITALS
// ─────────────────────────────────────────────

model Vital {
  id              String   @id @default(cuid())
  recordedAt      DateTime @default(now())

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  systolicBP      Int?
  diastolicBP     Int?
  heartRateBpm    Int?
  bloodOxygenPct  Float?
  temperatureC    Float?
  weightKg        Float?
  bloodGlucose    Float?
  respiratoryRate Int?

  source          String   @default("self_report")
  deviceId        String?
  notes           String?

  @@map("vitals")
}

// ─────────────────────────────────────────────
// RISK ASSESSMENT
// ─────────────────────────────────────────────

model RiskAssessment {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())

  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  overallRiskScore   Float
  overallRiskLevel   RiskLevel

  diabetesRisk       Float?
  hypertensionRisk   Float?
  cardiovascularRisk Float?

  modelVersion       String    @default("1.0.0")
  featuresUsed       String[]
  confidenceScore    Float?

  topRiskFactors     String[]
  priorityActions    String[]
  nextAssessmentDue  DateTime?

  @@map("risk_assessments")
}

model ChatSession {
  id         String              @id @default(cuid())
  startedAt  DateTime            @default(now())
  endedAt    DateTime?

  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    NotificationChannel @default(WHATSAPP)

  messages   Json                @default("[]")
  escalation Escalation?

  @@map("chat_sessions")
}



model Escalation {
  id               String           @id @default(cuid())
  createdAt        DateTime         @default(now())

  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId        String?          @unique
  session          ChatSession?     @relation(fields: [sessionId], references: [id])

  triggerMessage   String
  detectedKeywords String[]
  status           EscalationStatus @default(DETECTED)
  nearestClinicId  String?
  clinicName       String?
  clinicAddress    String?
  clinicPhone      String?
  resolvedAt       DateTime?
  resolvedNote     String?

  @@map("escalations")
}

// ─────────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────────

model Appointment {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())

  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  facilityName    String
  facilityAddress String?
  facilityPhone   String?
  appointmentType String
  scheduledAt     DateTime
  status          AppointmentStatus @default(SCHEDULED)
  reminderSentAt  DateTime?
  notes           String?
  completedAt     DateTime?
  outcome         String?

  @@map("appointments")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id          String              @id @default(cuid())
  createdAt   DateTime            @default(now())

  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel     NotificationChannel
  title       String
  body        String
  sentAt      DateTime?
  deliveredAt DateTime?
  openedAt    DateTime?
  type        String

  @@map("notifications")
}

// ─────────────────────────────────────────────
// GAIT LOGS (PWA accelerometer data)
// ─────────────────────────────────────────────

model GaitLog {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())

  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  timestamp           DateTime
  windowDurationSec   Int?
  sampleCount         Int?
  activity            String?
  stepsEstimated      Int?
  dominantAxis        String?
  meanMagnitude       Float?
  stdDevMagnitude     Float?
  gaitRegularityScore Float?
  fatigueIndex        Float?
  estimatedCalories   Float?
  movementDetected    Boolean  @default(false)
  prolongedStillness  Boolean  @default(false)
  highVariability     Boolean  @default(false)
  irregularGait       Boolean  @default(false)
  xMean               Float?
  yMean               Float?
  zMean               Float?
  xVariance           Float?
  yVariance           Float?
  zVariance           Float?

  @@index([userId, createdAt(sort: Desc)])
  @@map("gait_logs")
}
